{
  "version": 2,
  "installCommand": "rm -f pnpm-lock.yaml && npm ci",
  "buildCommand": "npm run build",
  "rewrites": [{ "source": "/(.*)", "destination": "/api" }],
  "functions": {
    "api/index.mjs": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "env": {
    "NODE_ENV": "production"
  }
}
